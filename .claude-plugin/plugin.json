{
  "name": "clone-wars",
  "version": "0.41.0",
  "description": "Multi-model tmux pane orchestration for Claude Code — spawn codex/gemini/claude TUIs as attachable clone troopers",
  "author": {
    "name": "WingsOfPanda",
    "email": "WingsOfPanda@users.noreply.github.com"
  },
  "homepage": "https://github.com/WingsOfPanda/clone-wars",
  "repository": "https://github.com/WingsOfPanda/clone-wars",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "plugin",
    "multi-agent",
    "orchestration",
    "tmux",
    "codex",
    "gemini"
  ],
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit-active-session.sh"
          }
        ]
      }
    ]
  }
}
